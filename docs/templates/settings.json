{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|compact|clear",
        "hooks": [
          {
            "type": "command",
            "command": "cat SOUL.md IDENTITY.md USER.md CONTEXT.md TRIGGERS.md MEMORY.md 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "python3 scripts/fetch_discord.py --limit 20 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "cat memory/cron-registry.md 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "cat SOUL.md IDENTITY.md USER.md CONTEXT.md TRIGGERS.md MEMORY.md 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
